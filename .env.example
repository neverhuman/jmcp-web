# JMCP local runtime defaults. These avoid Jeryu protected ports.
JMCP_API_BIND=127.0.0.1:18877
JMCP_API_URL=http://127.0.0.1:18877
JMCP_COCKPIT_HOST=127.0.0.1
JMCP_COCKPIT_PORT=8080
VITE_JMCP_TARGET=http://127.0.0.1:18877
VITE_VOICE_TARGET=http://127.0.0.1:8040
VITE_MINICPM_TARGET=http://127.0.0.1:8040
VITE_JMCP_BASE=/jmcp
VITE_VOICE_BASE=/voice
VITE_VOICE_WS_BASE=/voice-ws

# /voice and /voice-ws target the jmcp-talk local voice gateway. MiniCPM/Comni
# is an opt-in debug lane behind jmcp-talk, not the default browser TTS path.

# Optional Jeryu endpoint. If unset, JMCP discovers local Jeryu from config
# and then probes http://127.0.0.1:8799 and http://127.0.0.1:8787.
# JMCP_JERYU_URL=http://127.0.0.1:8799

# Optional Telegram polling runtime. Keep the token in telegram.env and set at
# least one allowlist; the bot fails closed when both allowlists are empty.
JMCP_TELEGRAM_POLL=false
JMCP_TELEGRAM_ENV=telegram.env
JMCP_TELEGRAM_OFFSET_FILE=jmcp.telegram.offset
# JMCP_TELEGRAM_ALLOWED_USER_IDS=123456789
# JMCP_TELEGRAM_ALLOWED_CHAT_IDS=-1001234567890
