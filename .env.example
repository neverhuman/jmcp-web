# JMCP local runtime defaults. These avoid Jeryu protected ports.
JMCP_API_BIND=127.0.0.1:18877
JMCP_API_URL=http://127.0.0.1:18877
JMCP_COCKPIT_HOST=127.0.0.1
JMCP_COCKPIT_PORT=15873

# Optional Jeryu endpoint. If unset, JMCP discovers local Jeryu from config
# and then probes http://127.0.0.1:8799 and http://127.0.0.1:8787.
# JMCP_JERYU_URL=http://127.0.0.1:8799
