{
  "name": "@neverhuman/jmcp",
  "version": "1.0.0",
  "private": true,
  "description": "JMCP V1 repository automation and schema gates.",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/cockpit",
    "apps/web",
    "packages/ux-qa"
  ],
  "scripts": {
    "doctor": "npm run typecheck",
    "fast": "npm run typecheck && npm run ux-qa:build && npm run ux-qa:test",
    "ci": "npm run fast && npm run test",
    "build": "npm --workspace @jmcp/cockpit run build",
    "typecheck": "npm --workspace @jmcp/cockpit run typecheck",
    "lint": "npm --workspace @jmcp/cockpit run lint",
    "test": "npm --workspace @jmcp/cockpit run test",
    "guard:no-three": "node scripts/no-three-guard.mjs",
    "guard:generated-client": "node scripts/generated-client-guard.mjs",
    "ux-qa:build": "npm --workspace @jankurai/ux-qa run build",
    "ux-qa:test": "npm --workspace @jankurai/ux-qa run test"
  }
}
